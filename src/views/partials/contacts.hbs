    <section id="contact" class="py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-8">
            <div class="reveal">
              <h2 class="section-title mb-3">Contact</h2>
              <p class="mb-4">
                I'd love to hear from you. Drop me a message below or reach out
                directly at
                <a
                  href="mailto:andrealfiannnnnn@gmail.com"
                  class="text-decoration-none"
                  >andrealfiannnnn@gmail.com</a
                >.
              </p>
            </div>

            <div class="d-flex flex-column gap-3 reveal" id="contactForm">
              <input type="text" class="form-control" placeholder="Your Name" />
              <input
                type="email"
                class="form-control"
                placeholder="Your Email"
              />
              <textarea
                class="form-control"
                rows="5"
                placeholder="Your Message"
              ></textarea>
              <div>
                <button class="btn-send" id="sendBtn" onclick="handleSubmit()">
                  Send Message
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>